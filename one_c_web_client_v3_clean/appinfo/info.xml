<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>one_c_web_client_v3</id>
    <name>1C WebClient v3</name>
    <summary>Динамический прокси для 1С:Предприятие</summary>
    <description><![CDATA[
        Приложение для доступа к системам 1С:Предприятие прямо из интерфейса Nextcloud.

        Возможности:
        - Динамический прокси для неограниченного количества баз 1С
        - Защита от неавторизованного доступа через cookie Nextcloud
        - Админ-панель для настройки баз через веб-интерфейс
        - Красивый адаптивный интерфейс
        - Полная поддержка Nextcloud 30-32
    ]]></description>
    <version>3.2.0</version>
    <licence>agpl</licence>
    <author mail="admin@example.com">Nextcloud Team</author>
    <namespace>OneCWebClient</namespace>
    <category>integration</category>
    <website>https://github.com/nextcloud/one_c_web_client</website>
    <bugs>https://github.com/nextcloud/one_c_web_client/issues</bugs>
    <repository type="git">https://github.com/nextcloud/one_c_web_client.git</repository>
    <screenshot>https://example.com/screenshot.png</screenshot>
    <dependencies>
        <nextcloud min-version="33" max-version="99"/>
        <php min-version="8.0" max-version="8.4"/>
        <lib>openssl</lib>
    </dependencies>
    <navigations>
        <navigation>
            <name>1C WebClient</name>
            <route>one_c_web_client.page.index</route>
        </navigation>
    </navigations>
    <settings>
        <admin>OCA\OneCWebClient\Settings\AdminSettings</admin>
        <admin-section>OCA\OneCWebClient\Settings\AdminSection</admin-section>
    </settings>
</info>